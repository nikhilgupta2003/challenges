{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user streak and progress information. Publicly readable for leaderboard.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "currentStreak": { "type": "integer" },
        "longestStreak": { "type": "integer" },
        "lastCompletionDate": { "type": "string", "format": "date-time" },
        "totalPoints": { "type": "integer" }
      },
      "required": ["uid", "currentStreak", "longestStreak", "totalPoints"]
    },
    "PrivateProfile": {
      "title": "Private User Profile",
      "description": "Stores sensitive user information like email.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["uid", "email"]
    },
    "Completion": {
      "title": "Challenge Completion",
      "description": "Records a user completing a specific challenge.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "challengeId": { "type": "string" },
        "category": { "type": "string" },
        "completedAt": { "type": "string", "format": "date-time" },
        "pointsEarned": { "type": "integer" }
      },
      "required": ["userId", "challengeId", "completedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public user profile and streak data."
    },
    "/private_profiles/{userId}": {
      "schema": "PrivateProfile",
      "description": "Private user data (e.g. email)."
    },
    "/completions/{completionId}": {
      "schema": "Completion",
      "description": "History of challenge completions."
    }
  }
}
